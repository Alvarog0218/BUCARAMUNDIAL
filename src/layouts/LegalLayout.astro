---
import BaseLayout from "./BaseLayout.astro";

const { title, description } = Astro.props;
const logo = "/assets/logo-bucara.png";
---

<BaseLayout title={title} description={description}>
  <header class="bg-[#071431] border-b border-brand-lime/20 py-5 px-6">
    <div class="container mx-auto max-w-4xl flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-3 group">
        <img src={logo} alt="Bucara es Mundial 2026" class="h-10 w-auto object-contain" />
      </a>
      <a
        href="/"
        class="text-[10px] font-black uppercase tracking-widest text-brand-lime hover:text-white transition-colors"
      >
        ← Volver al inicio
      </a>
    </div>
  </header>

  <main class="bg-brand-dark min-h-screen py-16 px-6">
    <div class="container mx-auto max-w-4xl">
      <article class="prose prose-invert prose-sm md:prose-base max-w-none
        prose-headings:font-black prose-headings:uppercase prose-headings:tracking-tight
        prose-h1:text-brand-lime prose-h1:text-3xl md:prose-h1:text-4xl prose-h1:italic prose-h1:mb-2
        prose-h2:text-white prose-h2:text-xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b prose-h2:border-brand-lime/20 prose-h2:pb-2
        prose-h3:text-brand-cyan prose-h3:text-base prose-h3:mt-6
        prose-p:text-gray-300 prose-p:leading-relaxed
        prose-li:text-gray-300
        prose-strong:text-white
        prose-a:text-brand-lime prose-a:no-underline hover:prose-a:text-brand-cyan
      ">
        <slot />
      </article>
    </div>
  </main>

  <footer class="bg-[#071431] border-t border-brand-lime/20 py-8 px-6 text-center">
    <p class="text-[10px] font-bold text-gray-500 uppercase tracking-widest">
      © 2026 Bucara es Mundial. Todos los derechos reservados. · Código PULEP: HPT643
    </p>
    <nav class="mt-4 flex flex-wrap justify-center gap-x-8 gap-y-3">
      <a href="/privacidad" class="text-[10px] font-black text-gray-400 hover:text-brand-lime uppercase tracking-widest transition-colors">Aviso de Privacidad</a>
      <a href="/terminos-evento" class="text-[10px] font-black text-gray-400 hover:text-brand-lime uppercase tracking-widest transition-colors">Términos del Evento</a>
      <a href="/tratamiento-datos" class="text-[10px] font-black text-gray-400 hover:text-brand-lime uppercase tracking-widest transition-colors">Tratamiento de Datos</a>
    </nav>
  </footer>
</BaseLayout>
