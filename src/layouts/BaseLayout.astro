---
import "../styles/global.css";

const {
  title = "Bucara Mundial | Neomundo 2026",
  description = "Landing page oficial de Bucara es Mundial en Neomundo Bucaramanga."
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/assets/logo-bucara.png" />
  </head>
  <body class="bg-brand-dark text-white antialiased">
    <slot />
    <a href="#inicio" class="back-to-top" aria-label="Volver al inicio">
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M12 5.5 5.5 12l1.7 1.7 3.6-3.6v8.4h2.4v-8.4l3.6 3.6 1.7-1.7L12 5.5Z" />
      </svg>
    </a>
    <script is:inline src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script src="../scripts/site.js"></script>
  </body>
</html>
