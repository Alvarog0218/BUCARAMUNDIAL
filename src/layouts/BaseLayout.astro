---
import "../styles/global.css";

const {
  title = "Bucaramundial 2026: Vive el Mundial en Pantalla Gigante en Bucaramanga - Neomundo",
  description = "Vive el Mundial 2026 en Neomundo Bucaramanga. Pantallas gigantes, ambiente de estadio, zona VIP y toda la emoción del fútbol. ¡Asegura tu entrada!",
  noindex = false
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || "https://bucaramundial.com");
const socialImageURL = new URL("/assets/hero-background.png", canonicalURL);
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="google-site-verification" content="2FH0xEmHFwv5GsWv9rfN9pj8miQfTdexsD1UQ6hZdEk" />
    
    <!-- SEO Primario -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- JSON-LD para Evento -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Event",
        "name": "Bucaramundial 2026",
        "description": "Vive el Mundial 2026 en la mejor pantalla gigante de Bucaramanga. Ambiente de estadio, comida y emoción en Neomundo.",
        "startDate": "2026-06-11T12:00:00-05:00",
        "endDate": "2026-07-19T23:59:59-05:00",
        "eventStatus": "https://schema.org/EventScheduled",
        "eventAttendanceMode": "https://schema.org/OfflineEventAttendanceMode",
        "location": {
          "@type": "Place",
          "name": "Neomundo Centro de Eventos y Convenciones",
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Calle 89 Transversal Oriental Metropolitana-69",
            "addressLocality": "Bucaramanga",
            "addressRegion": "Santander",
            "addressCountry": "CO"
          }
        },
        "image": [
          "https://bucaramundial.com/assets/hero-background.png"
        ],
        "offers": {
          "@type": "Offer",
          "url": "https://bucaramundial.com",
          "price": "0",
          "priceCurrency": "COP",
          "availability": "https://schema.org/InStock"
        },
        "organizer": {
          "@type": "Organization",
          "name": "Bucaramundial",
          "url": "https://bucaramundial.com"
        }
      }
    </script>

    <link rel="icon" type="image/png" href="/assets/logo-bucara.png" />
  </head>
  <body class="bg-brand-dark text-white antialiased">
    <slot />
    <button type="button" class="back-to-top" aria-label="Volver al inicio" data-back-to-top>
      <svg aria-hidden="true" viewBox="0 0 24 24">
        <path d="M12 5.5 5.5 12l1.7 1.7 3.6-3.6v8.4h2.4v-8.4l3.6 3.6 1.7-1.7L12 5.5Z" />
      </svg>
    </button>
    <script is:inline>
      document.querySelector("[data-back-to-top]")?.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    </script>
    <script src="../scripts/site.js"></script>
  </body>
</html>
>
