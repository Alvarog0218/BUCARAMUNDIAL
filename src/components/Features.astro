---
const background = "/assets/fondo-features.png";
---

<section class="py-24 relative z-20 overflow-hidden features-statement-background">
  <div class="absolute inset-0 z-0">
    <img src={background} alt="" aria-hidden="true" class="w-full h-full object-cover object-left" />
    <div class="absolute inset-0 bg-[#020617]/60"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="max-w-4xl mx-auto text-center">
      <h2 class="text-3xl md:text-5xl font-black italic uppercase tracking-tighter leading-tight text-brand-lime">
        La casa del mundial<br class="hidden md:block" /> en Bucaramanga
      </h2>
      <p class="mt-6 max-w-3xl mx-auto text-gray-300 font-bold uppercase tracking-widest text-xs md:text-sm leading-relaxed">
        Durante el Mundial, Neomundo es el punto de encuentro para vivir cada partido como debe ser:
        en pantalla gigante, con ambiente de estadio y toda la ciudad reunida.
      </p>
    </div>
  </div>
</section>
