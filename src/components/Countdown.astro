<section id="cuenta-regresiva" class="relative overflow-hidden bg-brand-dark py-14 sm:py-16">
  <div class="absolute inset-0 z-0 bg-[radial-gradient(circle_at_50%_0%,rgba(212,225,87,0.18),transparent_28rem)]"></div>
  <div class="absolute inset-x-0 top-0 z-0 h-px bg-brand-lime/35"></div>
  <div class="absolute inset-x-0 bottom-0 z-0 h-px bg-brand-cyan/25"></div>

  <div class="container relative z-10 mx-auto px-6 text-center">
    <div data-event-countdown aria-live="polite">
      <p class="mb-3 text-[11px] font-black uppercase tracking-[0.38em] text-brand-lime">Faltan</p>
      <div class="mx-auto grid w-full max-w-[min(92vw,680px)] gap-2 sm:gap-5">
        <div class="min-w-0 rounded-lg bg-white/[0.07] px-4 py-6 shadow-[0_22px_52px_rgba(0,0,0,0.32)] backdrop-blur-md sm:px-8 sm:py-8">
          <span class="block font-title text-[clamp(3.4rem,17vw,8rem)] leading-none text-white" data-countdown-value="days">00</span>
          <span class="mt-3 block text-[10px] font-black uppercase tracking-[0.28em] text-brand-cyan sm:text-xs">Dias</span>
        </div>

        <div class="grid grid-cols-3 gap-2 sm:gap-5">
          <div class="min-w-0 rounded-lg bg-white/[0.06] px-2 py-5 shadow-[0_18px_42px_rgba(0,0,0,0.28)] backdrop-blur-md sm:px-5 sm:py-6">
          <span class="block font-title text-[clamp(2rem,9vw,4.5rem)] leading-none text-white" data-countdown-value="hours">00</span>
          <span class="mt-3 block text-[9px] font-black uppercase tracking-[0.22em] text-brand-cyan sm:text-[11px]">Horas</span>
          </div>
          <div class="min-w-0 rounded-lg bg-white/[0.06] px-2 py-5 shadow-[0_18px_42px_rgba(0,0,0,0.28)] backdrop-blur-md sm:px-5 sm:py-6">
          <span class="block font-title text-[clamp(2rem,9vw,4.5rem)] leading-none text-white" data-countdown-value="minutes">00</span>
          <span class="mt-3 block text-[9px] font-black uppercase tracking-[0.22em] text-brand-cyan sm:text-[11px]">Min</span>
          </div>
          <div class="min-w-0 rounded-lg bg-white/[0.06] px-2 py-5 shadow-[0_18px_42px_rgba(0,0,0,0.28)] backdrop-blur-md sm:px-5 sm:py-6">
            <span class="block font-title text-[clamp(2rem,9vw,4.5rem)] leading-none text-white" data-countdown-value="seconds">00</span>
            <span class="mt-3 block text-[9px] font-black uppercase tracking-[0.22em] text-brand-cyan sm:text-[11px]">Seg</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
