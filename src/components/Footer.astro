---
const logo = "/assets/logo.png";
const sponsors = Array.from({ length: 10 }, (_, index) => index + 1);
const sponsorLoop = [...sponsors, ...sponsors];
---

<footer id="aliados" class="py-16 bg-brand-dark border-t border-brand-lime/20">
  <div class="container mx-auto px-6 text-center">
    <div class="mb-16">
      <h2 class="font-title text-2xl md:text-3xl font-black uppercase tracking-[0.2em] text-white mb-16 italic">
        Nuestros Aliados Estratégicos
      </h2>
      <div class="relative w-full overflow-hidden">
        <div class="absolute left-0 top-0 bottom-0 w-20 md:w-40 bg-gradient-to-r from-brand-dark to-transparent z-10 pointer-events-none"></div>
        <div class="absolute right-0 top-0 bottom-0 w-20 md:w-40 bg-gradient-to-l from-brand-dark to-transparent z-10 pointer-events-none"></div>

        <div class="animate-marquee gap-8 md:gap-12 pb-12 pt-4 items-center">
          {
            sponsorLoop.map((sponsor) => (
              <div class="flex-shrink-0 flex items-center justify-center transform transition-transform duration-300">
                <img
                  src={`/assets/patrocinadores/${sponsor}.png`}
                  alt={`Patrocinador ${sponsor}`}
                  class={`${sponsor === 3 ? "h-48 md:h-64" : "h-40 md:h-48"} w-auto object-contain neon-filter`}
                />
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <div class="flex flex-col md:flex-row justify-center items-center gap-8 pt-8 border-t border-brand-cyan/20">
      <div class="flex items-center gap-3">
        <img src={logo} alt="Logo" class="h-10 opacity-80" />
        <p class="text-[10px] font-bold text-gray-600 uppercase tracking-widest text-center md:text-left">
          © 2026 BUCARA ES MUNDIAL<br />NEOMUNDO BUCARAMANGA
        </p>
      </div>
    </div>
  </div>

  <div class="bg-brand-lime mt-12 py-6">
    <div class="container mx-auto px-6 flex flex-wrap justify-center gap-12 text-sm font-black text-brand-dark/60 uppercase tracking-widest">
      <a href="#" class="hover:text-brand-dark transition-colors">Aviso de Privacidad</a>
      <a href="#" class="hover:text-brand-dark transition-colors">Términos del Evento</a>
      <a href="#" class="hover:text-brand-dark transition-colors">Tratamiento de Datos</a>
    </div>
  </div>
</footer>
