---
const map = "/assets/zona-vip.png";
const zones = [
  {
    number: "1",
    name: "ZONA GENERAL",
    label: "AMBIENTE DE ESTADIO",
    subtitle: "Para vivir el partido con toda la energía de la ciudad",
    featured: false,
    color: "lime",
    description:
      "La zona para cantar, celebrar y sentir cada jugada en comunidad. Un espacio dinámico con pantallas grandes, ambiente futbolero y puntos cercanos para comprar comida y bebidas durante la jornada.",
    items: [
      "Pantallas grandes para seguir cada partido",
      "Ambiente futbolero con activaciones y celebración",
      "Espacios disponibles para comida, bebidas y snacks"
    ]
  },
  {
    number: "2",
    name: "ZONA INFANTIL",
    label: "DIVERSIÓN EN FAMILIA",
    subtitle: "Un lugar pensado para que los niños también vivan el Mundial",
    featured: false,
    color: "cyan",
    description:
      "Una experiencia segura, alegre y cómoda para familias. Los niños tendrán actividades recreativas mientras los adultos disfrutan el partido en un entorno organizado, con opciones de consumo y zonas pensadas para compartir.",
    items: [
      "Actividades infantiles y recreación supervisada",
      "Zonas cómodas para compartir en familia",
      "Opciones de comida y bebidas para grandes y pequeños"
    ]
  },
  {
    number: "3",
    name: "ZONA VIP",
    label: "EXPERIENCIA PREMIUM",
    subtitle: "Comodidad, buena vista y atención cerca del corazón del partido",
    featured: true,
    color: "magenta",
    description:
      "La zona para disfrutar el Mundial con mayor comodidad. Vive los partidos en asientos cómodos, con vista privilegiada a las pantallas grandes, ambiente futbolero y acceso cercano a espacios para comprar comida, bebidas y compartir sin perderte ninguna jugada.",
    items: [
      "Asientos cómodos y ubicación destacada",
      "Pantallas grandes y experiencia más cercana",
      "Comida, bebidas y puntos de encuentro a la mano"
    ]
  }
];
---

<section id="zonas" class="py-24 bg-brand-dark relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-full opacity-5 pointer-events-none">
    <div class="absolute top-10 left-10 w-64 h-64 bg-green-900 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 bg-yellow-900 rounded-full blur-3xl"></div>
  </div>

  <div class="container mx-auto px-6 relative z-10">
    <div class="text-center mb-16">
      <p class="text-brand-lime font-black uppercase tracking-[0.3em] mb-2">Bienvenidos a</p>
      <h2 class="text-5xl md:text-7xl font-black italic uppercase mb-4 tracking-tighter">La Casa del Mundial</h2>
      <div class="h-2 w-24 bg-brand-lime mx-auto"></div>
      <p class="mt-6 text-gray-400 max-w-2xl mx-auto font-bold uppercase tracking-widest text-[10px]">
        La casa no se recorre como un stand: SE VIVE COMO UNA EXPERIENCIA
      </p>
    </div>

    <div class="mb-20 max-w-5xl mx-auto">
      <div class="bg-brand-dark/40 border-2 border-brand-lime/20 rounded-[3rem] p-4 md:p-8 backdrop-blur-sm relative group shadow-2xl">
        <div class="text-left mb-6">
          <span class="bg-brand-lime text-brand-dark font-black px-4 py-1 rounded-full text-[10px] uppercase tracking-widest mb-2 inline-block">Mapa Oficial</span>
          <h3 class="text-2xl md:text-3xl font-black italic uppercase text-white">Distribución de Estaciones</h3>
          <p class="text-brand-lime text-[10px] font-bold uppercase tracking-widest mt-2">Haz clic en la imagen para ver completo</p>
        </div>
        <div class="absolute inset-0 bg-brand-lime/5 opacity-0 group-hover:opacity-100 transition-opacity rounded-[3rem] pointer-events-none"></div>
        <button
          type="button"
          data-open-modal={map}
          class="relative z-10 rounded-[2rem] overflow-hidden flex items-center justify-center cursor-zoom-in w-full"
          aria-label="Abrir mapa oficial"
        >
          <img src={map} alt="Distribución La Casa del Mundial" class="w-full h-auto block" />
        </button>
      </div>
      <p class="text-center mt-6 text-white font-bold uppercase tracking-widest text-[10px] italic">
        * La ubicación de las zonas puede variar según la logística del evento
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-stretch">
      {
        zones.map((zone) => (
          <article class={`${zone.featured ? "bg-brand-lime p-1 shadow-[0_0_50px_rgba(190,253,0,0.2)]" : zone.color === "cyan" ? "bg-brand-cyan/10 border-2 border-brand-cyan/70" : "bg-brand-blue/10 border-2 border-brand-lime/80"} rounded-3xl relative overflow-hidden group flex flex-col transition-transform hover:-translate-y-1`}>
            <div class={`${zone.featured ? "bg-brand-dark border-2 border-brand-lime rounded-[1.5rem] p-8 md:p-10 h-full" : "p-8 md:p-10 h-full"} flex flex-col`}>
              <div class="flex items-start justify-between gap-5 mb-8">
                <div>
                  <div class={`${zone.featured ? "bg-brand-magenta text-white" : zone.color === "cyan" ? "bg-brand-cyan text-brand-dark" : "bg-brand-lime text-brand-dark"} inline-flex px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-4`}>
                    {zone.label}
                  </div>
                  <h4 class="text-3xl font-black italic uppercase tracking-tighter leading-none text-white">
                    {zone.name}
                  </h4>
                </div>
                <span class={`${zone.featured ? "bg-brand-lime text-brand-dark" : zone.color === "cyan" ? "bg-brand-cyan text-brand-dark" : "bg-brand-lime text-brand-dark"} flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl text-xl font-black rotate-3`}>
                  {zone.number}
                </span>
              </div>

              <p class={`${zone.color === "cyan" ? "text-brand-cyan" : "text-brand-lime"} font-black mb-5 text-xs uppercase tracking-widest leading-relaxed`}>
                {zone.subtitle}
              </p>

              <p class="text-gray-300 text-sm md:text-base leading-relaxed font-semibold mb-8">
                {zone.description}
              </p>

              <ul class="mt-auto space-y-4 relative z-10">
                {zone.items.map((item) => (
                  <li class="flex gap-3 text-sm text-gray-200 font-bold leading-relaxed">
                    <span class={`${zone.color === "cyan" ? "text-brand-cyan" : "text-brand-lime"} mt-0.5 shrink-0 text-lg`}>
                      ★
                    </span>
                    <span>{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
