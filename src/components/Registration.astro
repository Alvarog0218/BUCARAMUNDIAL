---
const background = "/assets/balon-verde.png";

const ticketTypes = [
  ["individual", "Boleta individual"],
  ["abono", "Abono de evento"]
];

const zones = [
  ["General", "Zona General", "individual"],
  ["BIO", "Zona BIO", "individual"],
  ["VIP", "Zona VIP", "all"],
];
---

<section id="registro" class="py-16 md:py-20 relative overflow-hidden bg-brand-blue">
  <div class="absolute inset-0 z-0 bg-[#1f2b86]">
    <img
      src={background}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 registration-background-mark"
    />
    <div class="absolute inset-0 bg-[#020617]/55"></div>
  </div>

  <div class="container mx-auto px-6 max-w-2xl relative z-10">
    <div class="bg-brand-dark/90 backdrop-blur-xl p-5 md:p-8 rounded-[2rem] border-2 border-brand-lime shadow-2xl">
      <div id="selection-content">
        <h2 class="text-3xl md:text-4xl font-black mb-2 text-center uppercase italic tracking-tighter leading-none text-white">
          ASEGURA TU LUGAR
        </h2>
        <p class="text-brand-lime text-center mb-6 font-black uppercase tracking-widest text-[10px] md:text-xs">
          Completa tus datos para continuar con la compra
        </p>

        <form data-ticket-form novalidate class="bg-brand-blue/25 border border-brand-cyan/20 rounded-[1.5rem] p-5 md:p-6 shadow-xl max-w-lg mx-auto">
          <div class="flex items-center gap-3 mb-5">
            <div class="bg-brand-lime text-brand-dark w-10 h-10 rounded-full flex items-center justify-center shrink-0 shadow-md">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-lg font-black italic uppercase text-white">Datos de compra</h3>
              <p class="text-brand-lime text-[10px] font-black uppercase tracking-widest">
                Elige tu tipo de entrada y zona
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 gap-2.5">
            <div class="ticket-field" data-field-wrap="nombre">
              <label for="ticket-nombre">Nombre</label>
              <input id="ticket-nombre" name="nombre" type="text" required class="ticket-control" placeholder="Nombre completo" />
              <p class="ticket-field-message" data-field-error="nombre"></p>
            </div>

            <div class="ticket-field" data-field-wrap="whatsapp">
              <label for="ticket-whatsapp">Telefono</label>
              <input id="ticket-whatsapp" name="whatsapp" type="tel" required class="ticket-control" placeholder="Telefono" />
              <p class="ticket-field-message" data-field-error="whatsapp"></p>
            </div>

            <div class="ticket-field" data-field-wrap="email">
              <label for="ticket-email">Correo</label>
              <input id="ticket-email" name="email" type="email" required class="ticket-control" placeholder="Correo" />
              <p class="ticket-field-message" data-field-error="email"></p>
            </div>

            <div class="ticket-field" data-field-wrap="tipo">
              <label for="ticket-tipo">Tipo de compra</label>
              <div class="ticket-select-wrap">
                <select id="ticket-tipo" name="tipo" required class="ticket-control ticket-select ticket-type-select">
                  <option value="" disabled selected>Tipo de compra</option>
                  {ticketTypes.map(([value, label]) => (
                    <option value={value}>{label}</option>
                  ))}
                </select>
                <span aria-hidden="true" class="ticket-select-icon">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
              <p class="ticket-field-message" data-field-error="tipo"></p>
            </div>

            <div class="ticket-field" data-field-wrap="zona">
              <label for="ticket-zona">Zona</label>
              <div class="ticket-select-wrap">
                <select id="ticket-zona" name="zona" required disabled class="ticket-control ticket-select ticket-zone-select">
                  <option value="" disabled selected>Seleccionar zona</option>
                  {zones.map(([value, label, scope]) => (
                    <option value={value} data-ticket-scope={scope}>{label}</option>
                  ))}
                </select>
                <span aria-hidden="true" class="ticket-select-icon">
                  <svg viewBox="0 0 24 24" fill="none">
                    <path d="M6 9l6 6 6-6" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" />
                  </svg>
                </span>
              </div>
              <p class="ticket-field-message" data-field-error="zona"></p>
            </div>
          </div>

          <button
            type="submit"
            class="w-full bg-brand-lime hover:bg-brand-cyan text-brand-dark hover:text-white font-black py-3.5 rounded-xl text-sm transition-all shadow-lg uppercase italic tracking-tighter mt-4 disabled:opacity-70 disabled:cursor-not-allowed"
          >
            Ir a comprar
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
