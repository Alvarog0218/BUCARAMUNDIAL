---
const background = "/assets/balon-verde.png";

const ticketTypes = [
  ["individual", "Boleta individual"],
  ["abono", "Abono de evento"]
];

const zones = [
  ["General", "Zona General (BIO)", "individual"],
  ["VIP", "Zona VIP", "all"],
  ["Infantil", "Zona Infantil", "all"]
];
---

<section id="registro" class="py-24 relative overflow-hidden bg-brand-blue">
  <div class="absolute inset-0 z-0 bg-[#1f2b86]">
    <img
      src={background}
      alt=""
      aria-hidden="true"
      class="absolute inset-0 registration-background-mark"
    />
    <div class="absolute inset-0 bg-[#020617]/55"></div>
  </div>

  <div class="container mx-auto px-6 max-w-5xl relative z-10">
    <div class="bg-brand-dark/90 backdrop-blur-xl p-8 md:p-16 rounded-[3rem] border-4 border-brand-lime shadow-2xl">
      <div id="selection-content">
        <h2 class="text-4xl font-black mb-2 text-center uppercase italic tracking-tighter leading-none text-white">
          ASEGURA TU LUGAR
        </h2>
        <p class="text-brand-lime text-center mb-10 font-black uppercase tracking-widest text-xs">
          Completa tus datos para continuar con la compra
        </p>

        <form data-ticket-form class="bg-brand-blue/25 border-2 border-brand-cyan/20 rounded-[2.5rem] p-8 md:p-10 shadow-xl max-w-3xl mx-auto">
          <div class="flex items-center gap-4 mb-8">
            <div class="bg-brand-lime text-brand-dark w-12 h-12 rounded-full flex items-center justify-center shrink-0 shadow-md">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
              </svg>
            </div>
            <div>
              <h3 class="text-xl font-black italic uppercase text-white">Datos de compra</h3>
              <p class="text-brand-lime text-[10px] font-black uppercase tracking-widest">
                Elige tu tipo de entrada y zona
              </p>
            </div>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
            <input name="nombre" type="text" required class="w-full bg-brand-dark/70 border border-brand-cyan/20 rounded-xl py-3 px-4 focus:border-brand-lime outline-none transition-all font-bold placeholder:text-gray-500 uppercase text-xs italic text-white" placeholder="Nombre completo" />
            <input name="whatsapp" type="tel" required class="w-full bg-brand-dark/70 border border-brand-cyan/20 rounded-xl py-3 px-4 focus:border-brand-lime outline-none transition-all font-bold placeholder:text-gray-500 uppercase text-xs italic text-white" placeholder="WhatsApp" />
            <select name="tipo" required class="ticket-type-select w-full bg-brand-dark/70 border border-brand-cyan/20 rounded-xl py-3 px-4 focus:border-brand-lime outline-none transition-all font-bold uppercase text-xs italic text-white cursor-pointer">
              <option value="" disabled selected class="bg-brand-dark text-gray-500">Tipo de compra</option>
              {ticketTypes.map(([value, label]) => (
                <option value={value} class="bg-brand-dark text-white">{label}</option>
              ))}
            </select>
            <select name="zona" required disabled class="ticket-zone-select w-full bg-brand-dark/70 border border-brand-cyan/20 rounded-xl py-3 px-4 focus:border-brand-lime outline-none transition-all font-bold uppercase text-xs italic text-white cursor-pointer disabled:cursor-not-allowed disabled:opacity-60">
              <option value="" disabled selected class="bg-brand-dark text-gray-500">Seleccionar zona</option>
              {zones.map(([value, label, scope]) => (
                <option value={value} data-ticket-scope={scope} class="bg-brand-dark text-white">{label}</option>
              ))}
            </select>
            <input name="email" type="email" required class="md:col-span-2 w-full bg-brand-dark/70 border border-brand-cyan/20 rounded-xl py-3 px-4 focus:border-brand-lime outline-none transition-all font-bold placeholder:text-gray-500 uppercase text-xs italic text-white" placeholder="Tu mejor correo" />
          </div>

          <button
            type="submit"
            class="w-full bg-brand-lime hover:bg-brand-cyan text-brand-dark hover:text-white font-black py-4 rounded-xl text-sm transition-all shadow-lg uppercase italic tracking-tighter mt-6"
          >
            Ir a comprar
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
