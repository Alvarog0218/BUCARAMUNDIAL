---
const locationName = "Neomundo Bucaramanga";
const address = "Calle 89 Transversal Oriental Metropolitana-69, Barrio Tejar, Bucaramanga, Santander";

---

<section id="ubicacion" class="py-24 bg-brand-dark/30 relative overflow-hidden">
  <div class="container mx-auto px-6 relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <div class="order-1 lg:order-1">
        <div class="mb-10">
          <p class="text-brand-lime font-black uppercase tracking-[0.3em] text-xs mb-3">
            ¿Cómo llegar?
          </p>
          <h2 class="text-4xl md:text-6xl font-black italic uppercase mb-6 tracking-tighter leading-none text-white">
            Ubicación del <span class="text-brand-lime">Evento</span>
          </h2>
          <p class="text-xl text-white font-black italic uppercase mb-2">
            {locationName}
          </p>
          <p class="text-gray-400 font-semibold mb-8">
            {address}
          </p>
        </div>

        <div class="hidden lg:block mt-8">
          <button
            class="how-to-btn inline-flex items-center gap-3 px-10 py-5 rounded-full bg-brand-lime text-brand-dark font-black uppercase tracking-widest text-sm transition-all hover:bg-white hover:scale-105 hover:shadow-[0_0_30px_rgba(212,225,87,0.4)] active:scale-95 group"
          >
            <svg class="w-6 h-6 transition-transform group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            ¿Cómo llegar?
          </button>
        </div>
      </div>

      <div class="order-2 lg:order-2">
        <div class="relative group mb-10 lg:mb-0">
          <div class="absolute -inset-4 bg-brand-lime/20 rounded-[3rem] blur-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
          <div class="relative bg-brand-dark/50 border-2 border-brand-lime/20 rounded-[2.5rem] p-3 backdrop-blur-sm overflow-hidden shadow-2xl">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3959.270381617452!2d-73.10536492415124!3d7.100344516142371!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e683fba08827725%3A0x9599d14620f4f95e!2sNeomundo%20Centro%20de%20Eventos%20y%20Convenciones!5e0!3m2!1ses-419!2sco!4v1716912345678!5m2!1ses-419!2sco"
              width="100%"
              height="450"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              class="rounded-[2rem] grayscale hover:grayscale-0 transition-all duration-700"
            ></iframe>
          </div>
        </div>

        <div class="lg:hidden flex justify-center mt-8">
          <button
            class="how-to-btn w-full inline-flex items-center justify-center gap-3 px-10 py-5 rounded-full bg-brand-lime text-brand-dark font-black uppercase tracking-widest text-sm transition-all hover:bg-white hover:scale-105 hover:shadow-[0_0_30px_rgba(212,225,87,0.4)] active:scale-95 group"
          >
            <svg class="w-6 h-6 transition-transform group-hover:rotate-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            ¿Cómo llegar?
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btns = document.querySelectorAll('.how-to-btn');
  const address = "Calle 89 Transversal Oriental Metropolitana-69, Barrio Tejar, Bucaramanga, Santander";
  const coords = "7.100345,-73.102785";

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      const isMobile = /iPhone|iPad|iPod|Android/i.test(navigator.userAgent);
      
      if (isMobile) {
        const geoUrl = `geo:${coords}?q=${encodeURIComponent(address)}`;
        const appleUrl = `maps://maps.apple.com/?daddr=${encodeURIComponent(address)}`;
        
        if (/iPhone|iPad|iPod/i.test(navigator.userAgent)) {
          window.location.href = appleUrl;
        } else {
          window.location.href = geoUrl;
          setTimeout(() => {
            window.open(`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}`, '_blank');
          }, 500);
        }
      } else {
        window.open(`https://www.google.com/maps/dir/?api=1&destination=${encodeURIComponent(address)}`, '_blank');
      }
    });
  });
</script>
