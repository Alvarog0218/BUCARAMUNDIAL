---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Entrega de Premios | Bucaramundial">
  
  <main class="pt-12 md:pt-20 pb-20 relative min-h-screen">
    <!-- Background Image -->
    <div class="fixed inset-0 z-0 pointer-events-none">
      <img 
        src="/assets/balon-azul.png" 
        alt="" 
        class="w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-brand-dark/70"></div>
    </div>

    <section class="container mx-auto px-4 md:px-6 relative z-10">
      <!-- Pantalla de Login Simple -->
      <div id="staff-login" class="max-w-md mx-auto bg-brand-blue/20 p-8 rounded-[2rem] border-2 border-brand-lime/30 text-center shadow-2xl">
        <h1 class="text-3xl font-black italic uppercase text-white mb-2 tracking-tighter">Panel de Entrega</h1>
        <p class="text-brand-cyan text-[10px] font-black uppercase tracking-widest mb-6">Acceso exclusivo para personal de logística</p>
        <input type="password" id="staff-pass" placeholder="Contraseña de Entrega" class="w-full bg-brand-dark border-2 border-white/10 rounded-xl py-4 px-6 text-white font-bold mb-4 focus:border-brand-lime outline-none transition-all">
        <button id="login-btn" class="w-full bg-brand-lime hover:bg-white text-brand-dark font-black py-4 rounded-xl transition-all uppercase italic tracking-tighter text-lg shadow-lg">Entrar al Validador</button>
      </div>

      <!-- Contenido de Entrega (Oculto inicialmente) -->
      <div id="staff-content" class="hidden max-w-4xl mx-auto">
        <div class="flex flex-col md:flex-row justify-between items-center mb-10 gap-6">
          <div class="text-center md:text-left">
            <h1 class="text-4xl md:text-5xl font-black italic uppercase tracking-tighter text-brand-lime">
              Validar Cédula
            </h1>
            <p class="text-gray-400 text-xs font-bold uppercase tracking-widest">Validación de Ganadores y Entrega de Premios</p>
          </div>
          <button id="logout-btn" class="text-gray-400 hover:text-white uppercase font-bold text-[10px] tracking-widest border border-white/10 px-8 py-3 rounded-full transition-all hover:bg-white/5">Cerrar Sesión</button>
        </div>

        <!-- Manual Validator Card -->
        <div class="bg-brand-blue/20 border-2 border-brand-cyan/30 rounded-[2rem] md:rounded-[2.5rem] p-4 md:p-8 backdrop-blur-md shadow-2xl overflow-hidden">
          <div class="max-w-2xl mx-auto min-w-0">
            <div class="flex min-w-0 flex-col h-full">
              <div class="flex-1 min-w-0 p-4 md:p-6 bg-brand-dark/60 rounded-2xl md:rounded-3xl border border-white/10 flex flex-col overflow-hidden">
                <p class="text-[10px] font-black uppercase text-brand-cyan tracking-widest mb-4">Validación de Identidad</p>
                
                <div class="flex min-w-0 flex-col gap-2 mb-6 sm:flex-row">
                  <input type="text" id="manual-cedula" inputmode="numeric" pattern="[0-9]*" autocomplete="off" placeholder="Número de Cédula" class="min-w-0 flex-1 bg-brand-dark border-2 border-white/10 rounded-xl py-3 px-4 text-white font-bold outline-none focus:border-brand-lime transition-all text-sm">
                  <button id="search-cedula-btn" class="w-full bg-brand-lime hover:bg-white text-brand-dark font-black px-6 py-3 rounded-xl uppercase italic text-xs transition-all shadow-lg sm:w-auto">Buscar</button>
                </div>

                <div id="scan-result" class="flex-1 min-w-0 flex flex-col justify-center text-center overflow-hidden">
                  <div class="py-10">
                    <div class="w-16 h-16 border-4 border-dashed border-white/10 rounded-full mx-auto mb-4 flex items-center justify-center">
                      <svg class="w-8 h-8 text-white/10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
                    </div>
                    <p class="text-gray-500 font-bold uppercase italic text-sm">Digita una cédula para validar</p>
                  </div>
                </div>
              </div>

              <!-- Help text -->
              <div class="mt-6 px-2 space-y-2">
                <div class="flex items-start gap-3">
                  <span class="w-5 h-5 rounded-full bg-brand-cyan/20 text-brand-cyan flex-shrink-0 flex items-center justify-center text-[10px] font-bold">1</span>
                  <p class="text-[10px] text-gray-400 font-medium leading-relaxed">Digita el número de documento y presiona Buscar.</p>
                </div>
                <div class="flex items-start gap-3">
                  <span class="w-5 h-5 rounded-full bg-brand-cyan/20 text-brand-cyan flex-shrink-0 flex items-center justify-center text-[10px] font-bold">2</span>
                  <p class="text-[10px] text-gray-400 font-medium leading-relaxed">Verifica que el nombre coincida y que no tenga entregas previas.</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <script src="../scripts/entrega-premios.js"></script>
  <Footer />
</BaseLayout>
